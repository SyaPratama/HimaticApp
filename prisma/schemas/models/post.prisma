model Posts {
    id String @id @default(cuid())
    title String
    slug String
    description String @db.Text
    content String @db.Text
    categories Categories @relation(fields: [categorieId], references: [id])
    categorieId String
    tags TagsOnPosts[]
    totalView Int
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    postFiles FileOnPosts[]
    view ViewOnPosts[]
}

model Views {
    id String @id @default(cuid())
    ip_address String
    userAgent String
    createdAt DateTime @default(now())
    expiredAt Int
    post ViewOnPosts[]
}

model ViewOnPosts {
    id String @id @default(cuid())
    view Views @relation(fields: [viewId], references: [id])
    viewId String
    post Posts @relation(fields: [postId], references: [id])
    postId String
}

model TagsOnPosts {
    id String @id @default(cuid())
    post Posts @relation(fields: [postId], references: [id])
    postId String
    tag Tags @relation(fields: [tagId], references: [id])
    tagId String
    createdAt DateTime @default(now())
}

model FileOnPosts {
    id String @id @default(cuid())
    filePath FilePath @relation(fields: [fileImagePath], references: [id])
    fileImagePath String
    post Posts @relation(fields: [postId], references: [id])
    postId String
}

model Categories {
    id String @id @default(cuid())
    name String @unique @db.VarChar(100)
    description String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    posts Posts[]
}

model Tags {
    id String @id @default(cuid())
    name String @unique @db.VarChar(100)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    posts TagsOnPosts[]
}